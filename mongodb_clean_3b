from pymongo import MongoClient
from tqdm import tqdm

client = MongoClient("mongodb://localhost:27017")
db = client["final_db_macpro_3"]
tweets_collection = db["tweets_final_macpro_3"]

# List of fields to keep
fields_to_keep = set([
    "_id", "created_at", "id_str", "text", "in_reply_to_status_id_str",
    "in_reply_to_user_id", "in_reply_to_user_id_str", "in_reply_to_screen_name",
    "place", "quoted_status_id_str", "possibly_sensitive", "lang",
    "entities_hashtags", "entities_user_mentions", "user_id_str",
    "root", "replied", "conversation_ids", "sentiment", "translated_text"
])

# Iterate through all tweets and remove unwanted fields
for tweet in tqdm(tweets_collection.find({})):
    current_fields = set(tweet.keys())
    fields_to_remove = current_fields - fields_to_keep

    if fields_to_remove:
        unset_dict = {field: "" for field in fields_to_remove}
        tweets_collection.update_one(
            {"_id": tweet["_id"]},
            {"$unset": unset_dict}
        )

print("Cleanup complete.")